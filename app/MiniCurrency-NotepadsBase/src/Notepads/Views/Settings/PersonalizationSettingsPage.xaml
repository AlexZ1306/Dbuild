<Page
    x:Class="Notepads.Views.Settings.PersonalizationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SystemControlForegroundTransparentBrush}">

    <Grid>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="25" FromVerticalOffset="0"/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.BackgroundTransition>
            <BrushTransition />
        </Grid.BackgroundTransition>

        <ScrollViewer
            Grid.Row="0"
            Padding="20,0,20,0"
            IsTabStop="False"
            UseSystemFocusVisuals="False"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,40">
                <TextBlock
                    x:Uid="/Settings/PersonalizationPage_ThemeModeSettings_Title"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,15,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="ThemePanel" Margin="0,10,0,0">
                    <RadioButton x:Uid="/Settings/PersonalizationPage_ThemeModeSettings_LightModeRadioButton" Style="{StaticResource CustomRadioButtonStyle}" x:Name="ThemeModeLightButton" Tag="Light" />
                    <RadioButton x:Uid="/Settings/PersonalizationPage_ThemeModeSettings_DarkModeRadioButton" Style="{StaticResource CustomRadioButtonStyle}" x:Name="ThemeModeDarkButton" Tag="Dark" />
                    <RadioButton x:Uid="/Settings/PersonalizationPage_ThemeModeSettings_WindowsModeRadioButton" Style="{StaticResource CustomRadioButtonStyle}" x:Name="ThemeModeDefaultButton" Tag="Default" />
                </StackPanel>
                <TextBlock x:Name="BackgroundTintOpacityTitle"
                    x:Uid="/Settings/PersonalizationPage_BackgroundTintOpacitySettings_Title"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="BackgroundTintOpacityControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}" 
                                x:Name="BackgroundTintOpacitySlider"
                                Minimum="0" Maximum="100" 
                                StepFrequency="1"
                                Margin="0,0,10,0" 
                                Width="200"/>
                        <TextBlock Text="{x:Bind BackgroundTintOpacitySlider.Value, Mode=OneWay}"
                                   Height="{x:Bind BackgroundTintOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center" 
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind BackgroundTintOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center" 
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock x:Uid="/Settings/PersonalizationPage_BackgroundTintOpacitySettings_Description" Style="{ThemeResource DescriptionTextBlockStyle}" Margin="0,8,0,0"/>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyUiScaleTitle"
                    Text="Масштаб MiniCurrency"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyUiScaleControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyUiScaleSlider"
                                Minimum="0" Maximum="100"
                                StepFrequency="1"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyUiScaleSlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyUiScaleSlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind MiniCurrencyUiScaleSlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock Text="50% — текущий размер (меньше 50% уменьшает, больше 50% увеличивает)"
                               Style="{ThemeResource DescriptionTextBlockStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyActiveCardOpacityTitle"
                    Text="Непрозрачность активной подложки MiniCurrency"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyActiveCardOpacityControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyActiveCardOpacitySlider"
                                Minimum="0" Maximum="100"
                                StepFrequency="1"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyActiveCardOpacitySlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyActiveCardOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind MiniCurrencyActiveCardOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock Text="Регулирует непрозрачность активной подложки строки, где вводится сумма"
                               Style="{ThemeResource DescriptionTextBlockStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyCardOpacityTitle"
                    Text="Непрозрачность неактивных подложек MiniCurrency"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyCardOpacityControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyCardOpacitySlider"
                                Minimum="0" Maximum="100"
                                StepFrequency="1"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyCardOpacitySlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyCardOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind MiniCurrencyCardOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock Text="Регулирует непрозрачность подложек под флагами, кодами и суммами валют (100% — плотный цвет)"
                               Style="{ThemeResource DescriptionTextBlockStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyValueFontWeightTitle"
                    Text="Жирность шрифта суммы MiniCurrency"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyValueFontWeightControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyValueFontWeightSlider"
                                Minimum="100" Maximum="900"
                                StepFrequency="100"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyValueFontWeightSlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyValueFontWeightSlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock Text="Меняет только жирность текста суммы на главном экране (100 — тонкий, 900 — очень жирный)"
                               Style="{ThemeResource DescriptionTextBlockStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyInactiveCardColorTitle"
                    Text="Цвет неактивных подложек MiniCurrency"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyInactiveCardColorControls" Margin="0,10,0,0">
                    <ToggleSwitch x:Name="MiniCurrencyUseDefaultInactiveCardColorToggle"
                                  Style="{StaticResource CustomToggleSwitchStyle}"
                                  Header="Использовать цвет по умолчанию"
                                  Margin="0,0,0,8"/>
                    <Viewbox MaxWidth="300" Stretch="Fill">
                        <ColorPicker
                            x:Name="MiniCurrencyInactiveCardColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="True"
                            IsHexInputVisible="True"
                            IsAlphaEnabled="False"
                            IsAlphaSliderVisible="False"
                            IsAlphaTextInputVisible="False">
                        </ColorPicker>
                    </Viewbox>
                    <TextBlock Text="Настраивает базовый цвет неактивных подложек (флаг/код и сумма). Прозрачность регулируется отдельным ползунком выше"
                               Style="{ThemeResource DescriptionTextBlockStyle}"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
                <TextBlock
                    x:Uid="/Settings/PersonalizationPage_AccentColorSettings_Title"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel Margin="0,10,0,0">
                    <ToggleSwitch x:Uid="/Settings/PersonalizationPage_AccentColorSettings_UseWindowsAccentColorToggleSwitch" Style="{StaticResource CustomToggleSwitchStyle}" x:Name="AccentColorToggle" Margin="0,0,0,8"/>
                    <Viewbox MaxWidth="300" Stretch="Fill">
                        <ColorPicker
                            x:Name="AccentColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="True"
                            IsHexInputVisible="True"
                            IsAlphaEnabled="False"
                            IsAlphaSliderVisible="True"
                            IsAlphaTextInputVisible="True">
                        </ColorPicker>
                    </Viewbox>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyCalculatorStyleTitle"
                    Text="Стиль кнопок калькулятора"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <TextBlock
                    x:Name="MiniCurrencyCalculatorEqualsButtonColorTitle"
                    Text="Цвет кнопки ="
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyCalculatorEqualsButtonColorControls" Margin="0,10,0,0">
                    <ToggleSwitch x:Name="MiniCurrencyCalculatorUseWindowsEqualsColorToggle"
                                  Style="{StaticResource CustomToggleSwitchStyle}"
                                  Header="Использовать цвет Windows по умолчанию"
                                  Margin="0,0,0,8"/>
                    <Viewbox MaxWidth="300" Stretch="Fill">
                        <ColorPicker
                            x:Name="MiniCurrencyCalculatorEqualsButtonColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="True"
                            IsHexInputVisible="True"
                            IsAlphaEnabled="False"
                            IsAlphaSliderVisible="False"
                            IsAlphaTextInputVisible="False">
                        </ColorPicker>
                    </Viewbox>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyCalculatorEqualsButtonOpacitySlider"
                                Minimum="0" Maximum="100"
                                StepFrequency="1"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyCalculatorEqualsButtonOpacitySlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyCalculatorEqualsButtonOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind MiniCurrencyCalculatorEqualsButtonOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyCalculatorDigitTextColorTitle"
                    Text="Цвет подложки цифр и запятой"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyCalculatorDigitTextColorControls" Margin="0,10,0,0">
                    <Viewbox MaxWidth="300" Stretch="Fill">
                        <ColorPicker
                            x:Name="MiniCurrencyCalculatorDigitTextColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="True"
                            IsHexInputVisible="True"
                            IsAlphaEnabled="False"
                            IsAlphaSliderVisible="False"
                            IsAlphaTextInputVisible="False">
                        </ColorPicker>
                    </Viewbox>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyCalculatorOperatorTextColorTitle"
                    Text="Цвет подложки кнопок операций"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyCalculatorOperatorTextColorControls" Margin="0,10,0,0">
                    <Viewbox MaxWidth="300" Stretch="Fill">
                        <ColorPicker
                            x:Name="MiniCurrencyCalculatorOperatorTextColorPicker"
                            ColorSpectrumShape="Ring"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="True"
                            IsHexInputVisible="True"
                            IsAlphaEnabled="False"
                            IsAlphaSliderVisible="False"
                            IsAlphaTextInputVisible="False">
                        </ColorPicker>
                    </Viewbox>
                </StackPanel>
                <TextBlock
                    x:Name="MiniCurrencyCalculatorButtonsOpacityTitle"
                    Text="Непрозрачность кнопок калькулятора (кроме =)"
                    Style="{StaticResource CompactSubtitleTextBlockStyle}"
                    Margin="0,20,0,0"
                    FontWeight="Normal"/>
                <StackPanel x:Name="MiniCurrencyCalculatorButtonsOpacityControls" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Slider Style="{StaticResource CustomSliderStyle}"
                                x:Name="MiniCurrencyCalculatorButtonsOpacitySlider"
                                Minimum="0" Maximum="100"
                                StepFrequency="1"
                                Margin="0,0,10,0"
                                Width="200"/>
                        <TextBlock Text="{x:Bind MiniCurrencyCalculatorButtonsOpacitySlider.Value, Mode=OneWay}"
                                   Height="{x:Bind MiniCurrencyCalculatorButtonsOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                        <TextBlock Text="%"
                                   Height="{x:Bind MiniCurrencyCalculatorButtonsOpacitySlider.Height, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
